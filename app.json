{
  "expo": {
    "name": "conductor-mobile",
    "slug": "conductor-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "conductormobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jamesftl.conductormobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UNNotificationCategories": [
          {
            "identifier": "SIGNAL_FOLLOWUP",
            "actions": [
              { "identifier": "REST", "title": "Done ✓", "options": [] },
              { "identifier": "HOLD", "title": "Still open", "options": [] }
            ]
          },
          {
            "identifier": "PACKAGE_TRACKING",
            "actions": [
              { "identifier": "REST", "title": "Got it ✓", "options": [] },
              { "identifier": "TRACK", "title": "Track", "options": ["foreground"] }
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Conductor reads your health data to provide personalized context in your morning brief.",
          "NSHealthUpdateUsageDescription": "Conductor does not write health data."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Conductor uses your photo library to add photos to crew member profiles."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04f4211f-0b25-420c-b079-4e7e394dfb76"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/04f4211f-0b25-420c-b079-4e7e394dfb76"
    }
  }
}

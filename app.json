{
  "expo": {
    "name": "conductor-mobile",
    "slug": "conductor-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "conductormobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jamesftl.conductormobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UNNotificationCategories": [
          {
            "identifier": "SIGNAL_FOLLOWUP",
            "actions": [
              { "identifier": "REST", "title": "Done ✓", "options": [] },
              { "identifier": "HOLD", "title": "Still open", "options": [] }
            ]
          },
          {
            "identifier": "PACKAGE_TRACKING",
            "actions": [
              { "identifier": "REST", "title": "Got it ✓", "options": [] },
              { "identifier": "TRACK", "title": "Track", "options": ["foreground"] }
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "package": "com.jamesftl.conductormobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Conductor reads your health data to provide personalized context in your morning brief.",
          "NSHealthUpdateUsageDescription": "Conductor does not write health data."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Conductor uses your photo library to add photos to crew member profiles."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04f4211f-0b25-420c-b079-4e7e394dfb76"
      },
      "alternateIcons": {
        "january":   { "image": "./assets/icons/icon-january.png" },
        "february":  { "image": "./assets/icons/icon-february.png" },
        "march":     { "image": "./assets/icons/icon-march.png" },
        "april":     { "image": "./assets/icons/icon-april.png" },
        "may":       { "image": "./assets/icons/icon-may.png" },
        "june":      { "image": "./assets/icons/icon-june.png" },
        "july":      { "image": "./assets/icons/icon-july.png" },
        "august":    { "image": "./assets/icons/icon-august.png" },
        "september": { "image": "./assets/icons/icon-september.png" },
        "october":   { "image": "./assets/icons/icon-october.png" },
        "november":  { "image": "./assets/icons/icon-november.png" },
        "december":  { "image": "./assets/icons/icon-december.png" },
        "founding":  { "image": "./assets/icons/icon-founding.png" }
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/04f4211f-0b25-420c-b079-4e7e394dfb76"
    }
  }
}
